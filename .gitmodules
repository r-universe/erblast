[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "easyalluvial"]
	path = easyalluvial
	url = https://github.com/erblast/easyalluvial
	shallow = true
	registered = true
[submodule "parcats"]
	path = parcats
	url = https://github.com/erblast/parcats
	shallow = true
	registered = true
